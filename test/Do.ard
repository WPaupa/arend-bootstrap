\import Utilities.Monad
\import Monad.Do

-- bind then result
\func test1 {M : Monad} {A B : \Set} (ma : M A) (mb : A -> M B) : M B => do {
  \lam a => ma,
  mb a
}

-- sequencing (discarding results)
\func test2 {M : Monad} {A : \Set} (ma mb : M A) : M A => do {
  ma,
  mb
}

-- single statement
\func test3 {M : Monad} {A : \Set} (a : A) : M A => do {
  return a
}

-- mixed binds and sequencing
\func test4 {M : Monad} {A B : \Set} (ma : M A) (mb : M B) (k : A -> B -> M A) : M A => do {
  \lam a => ma,
  mb,
  \lam b => mb,
  (\lam x => k x b) a
}

-- pure (non-monadic) let-binding interleaved with binds
\func test5 {M : Monad} : M Nat => do {
  \lam a => return 1,
  \let b => 1,
  return (a Nat.+ b)
}

-- let-binding with several clauses, used by a later bind
\func test6 {M : Monad} {A : \Set} (f : Nat -> M A) : M A => do {
  \let | x => 2 | y => 3,
  \lam a => f (x Nat.* y),
  return a
}